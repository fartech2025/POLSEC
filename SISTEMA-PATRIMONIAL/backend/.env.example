# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Sistema Patrimonial POLSEC"
APP_VERSION="2.0.0"
DEBUG=false

# ── Supabase ──────────────────────────────────────────────────────────────────
# URL do projeto Supabase (ex: https://xyzabc.supabase.co)
SUPABASE_URL=https://<project-id>.supabase.co

# Chave anon (pública) — encontrada em Settings → API
SUPABASE_ANON_KEY=eyJ...

# Chave service_role (privada) — NUNCA exponha ao frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# JWT Secret do projeto — Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=seu-jwt-secret-aqui

# ── Banco de dados ────────────────────────────────────────────────────────────
# Connection pooler (Transaction mode) — Settings → Database → Connection string
DATABASE_URL=postgresql+psycopg://postgres.<project-id>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ── IA (Anthropic Claude) ─────────────────────────────────────────────────────
# Chave global de fallback — cada tenant pode configurar a sua própria via /admin/integracoes
ANTHROPIC_API_KEY=sk-ant-...

# ── Segurança ─────────────────────────────────────────────────────────────────
# Chave Fernet para cifrar dados sensíveis (api keys de tenants) no banco.
# OBRIGATÓRIO. Gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# Diretório para relatórios de auditoria de segurança (opcional, padrão: /tmp)
# SEC_AUDIT_DIR=/var/log/polsec

